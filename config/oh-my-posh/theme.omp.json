{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "\u256d\u2500\ue0b6",
          "foreground": "#1a1b26",
          "background": "#c0caf5",
          "template": " {{ if .WSL }}\ue62a {{ end }}{{.Icon}} "
        },
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#ffffff",
          "background": "#7aa2f7",
          "template": " {{ .UserName }}@{{ .HostName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#1a1b26",
          "background": "#bb9af7",
          "options": {
            "home_icon": "\uf015",
            "style": "agnoster_short",
            "max_depth": 3
          },
          "template": " \uf07c {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#1a1b26",
          "background": "#9ece6a",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#e0af68{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#f7768e{{ end }}",
            "{{ if gt .Ahead 0 }}#7dcfff{{ end }}",
            "{{ if gt .Behind 0 }}#73daca{{ end }}"
          ],
          "options": {
            "branch_icon": "\uf126 ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "node",
          "style": "powerline",
          "powerline_symbol": "\ue0b2",
          "invert_powerline": true,
          "foreground": "#ffffff",
          "background": "#689f63",
          "template": " {{ .Full }} \ue718 "
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "\ue0b2",
          "invert_powerline": true,
          "foreground": "#1a1b26",
          "background": "#FFDE57",
          "options": {
            "display_mode": "context",
            "fetch_virtual_env": true
          },
          "template": " {{ .Full }}{{ if .Venv }} ({{ .Venv }}){{ end }} \ue235 "
        },
        {
          "type": "rust",
          "style": "powerline",
          "powerline_symbol": "\ue0b2",
          "invert_powerline": true,
          "foreground": "#ffffff",
          "background": "#CE412B",
          "template": " {{ .Full }} \ue7a8 "
        },
        {
          "type": "aws",
          "style": "powerline",
          "powerline_symbol": "\ue0b2",
          "invert_powerline": true,
          "foreground": "#1a1b26",
          "background": "#FF9900",
          "options": {
            "display_default": false
          },
          "template": " {{ .Profile }}{{ if .Region }}@{{ .Region }}{{ end }} \ue7ad "
        },
        {
          "type": "executiontime",
          "style": "powerline",
          "powerline_symbol": "\ue0b2",
          "invert_powerline": true,
          "foreground": "#c0caf5",
          "background": "#414868",
          "options": {
            "threshold": 2000
          },
          "template": " {{ .FormattedMs }} \uf252 "
        },
        {
          "type": "status",
          "style": "powerline",
          "powerline_symbol": "\ue0b2",
          "invert_powerline": true,
          "foreground": "#c0caf5",
          "background": "#1a1b26",
          "background_templates": [
            "{{ if gt .Code 0 }}#f7768e{{ end }}"
          ],
          "options": {
            "always_enabled": true
          },
          "template": " {{ if gt .Code 0 }}{{ reason .Code }}{{ else }}\uf42e{{ end }} "
        },
        {
          "type": "time",
          "style": "diamond",
          "trailing_diamond": "\ue0b0\u2500\u256e",
          "invert_powerline": true,
          "foreground": "#1a1b26",
          "background": "#c0caf5",
          "template": " {{ .CurrentDate | date .Format }} \uf017 ",
          "options": {
            "time_format": "15:04"
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#c0caf5",
          "template": "\u2570\u2500"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#9ece6a",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#f7768e{{ end }}"
          ],
          "template": " \u276f"
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#c0caf5",
          "template": "\u2500\u256f"
        }
      ]
    }
  ],
  "transient_prompt": {
    "foreground": "#9ece6a",
    "foreground_templates": [
      "{{ if gt .Code 0 }}#f7768e{{ end }}"
    ],
    "template": "\u276f "
  }
}
